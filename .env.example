# Firebase 設定（プロジェクトを作成して取得）
# https://console.firebase.google.com/ でプロジェクト作成 → ⚙ プロジェクト設定 → マイアプリ → SDKの設定と構成
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxx

# GitHub Pages の base path
# 例: https://USERNAME.github.io/teiki-segment-plan/  →  /teiki-segment-plan/
# ユーザーページ（USERNAME.github.io）として公開する場合は /
VITE_BASE=/teiki-segment-plan/

# Claude (Anthropic) API — AI アシスタント機能用
# ============================================================================
# 【推奨】proxy モード — Cloudflare Workers 経由でキーを隠す
#   workers/claude-proxy/ を先に deploy してから URL を設定する
#   Worker 側で Firebase ID token 検証 → Anthropic API へ転送
VITE_CLAUDE_PROXY_URL=https://claude-proxy.xxx.workers.dev

# 【非推奨】直接モード — キーがクライアントバンドルに埋め込まれる（露出リスク）
#   proxy が設定されていればこちらは無視される
# VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# モデル（任意）。未指定なら claude-sonnet-4-6
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
